# Database
DATABASE_URL=postgresql://user:password@localhost:5432/discoveryos
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=1

# AI
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
AI_PRIMARY_MODEL=gemini-1.5-flash
AI_FALLBACK_MODEL=llama-3.1-70b-versatile

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=discoveryos-uploads

# CORS
CORS_ORIGINS=http://localhost:3000,https://app.discoveryos.com

# Environment
ENV=development
LOG_LEVEL=INFO